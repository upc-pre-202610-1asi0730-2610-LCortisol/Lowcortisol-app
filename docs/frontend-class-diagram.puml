@startuml
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam shadowing false
skinparam linetype ortho

title LowCortisol - Frontend Class Diagram

package "Presentation" {

  package "Pages" {
    class LoginPage {
      - email : string
      - password : string
      - errorMessage : string
      - isSubmitting : bool
      - _checkedSession : bool
      + SignInAsync()
      + OnAfterRenderAsync(firstRender)
    }

    class RegisterPage {
      - name : string
      - email : string
      - phone : string
      - password : string
      - role : string
      - errorMessage : string
      - isSubmitting : bool
      - _checkedSession : bool
      + RegisterAsync()
      + OnAfterRenderAsync(firstRender)
    }

    class HomePage {
      - _checkedSession : bool
      + OnAfterRenderAsync(firstRender)
    }

    class DevicesPage {
      - devices : List<DeviceDto>
      - showCreatePanel : bool
      - isSubmitting : bool
      - errorMessage : string
      - fatalError : string
      - _checkedSession : bool
      - isLoadingPage : bool
      - newDeviceName : string
      - newDeviceType : string
      - newDeviceStatus : string
      - newDeviceLocation : string
      - newThresholdValue : decimal?
      - newThresholdUnit : string?
      + LoadDevicesAsync()
      + OpenCreatePanel()
      + CloseCreatePanel()
      + CreateDeviceAsync()
      + ChangeStatusAsync(deviceId, status)
      + OnAfterRenderAsync(firstRender)
    }

    class ReportsPage {
      - reports : List<ConsumptionReportDto>
      - showGeneratePanel : bool
      - isSubmitting : bool
      - errorMessage : string
      - fatalError : string
      - selectedPeriod : string
      - _checkedSession : bool
      - isLoadingPage : bool
      - newPeriod : string
      - newWaterTotal : decimal
      - newWaterUnit : string
      - newGasTotal : decimal
      - newGasUnit : string
      + LoadReportsAsync()
      + OpenGeneratePanel()
      + CloseGeneratePanel()
      + GenerateReportAsync()
      + SelectPeriodAsync(period)
      + BuildBars()
      + OnAfterRenderAsync(firstRender)
    }

    class AlertsPage {
      - incidents : List<IncidentDto>
      - devices : List<DeviceDto>
      - showCreatePanel : bool
      - isSubmitting : bool
      - errorMessage : string
      - fatalError : string
      - _checkedSession : bool
      - isLoadingPage : bool
      - selectedDeviceId : string
      - newSeverity : string
      - newDescription : string
      + LoadDevicesAsync()
      + LoadIncidentsAsync()
      + OpenCreatePanel()
      + CloseCreatePanel()
      + CreateIncidentAsync()
      + AssignToCurrentUserAsync(incidentId)
      + UpdateStatusAsync(incidentId, status, note)
      + OnAfterRenderAsync(firstRender)
    }

    class ProfilePage {
      - _checkedSession : bool
      + SignOut()
      + TranslateRole(role)
      + GetPermissionSummary(role)
      + OnAfterRenderAsync(firstRender)
    }
  }

  package "Layout" {
    class MainLayout {
      + SetLanguage(language)
      + GetLangButtonClass(language)
      + IsPublicPage()
      + Refresh()
    }
  }

  package "Services" {
    class I18nService {
      - _translations : Dictionary<String,String>
      + CurrentLanguage : string
      + OnChange : Action
      + this[key] : string
      + SetLanguageAsync(language)
      - LoadLanguage(language)
    }

    class BrowserSessionService {
      - UserIdKey : string
      + SaveUserIdAsync(userId)
      + GetUserIdAsync()
      + ClearAsync()
    }

    class UiSessionService {
      + IsAuthenticated : bool
      + CurrentUser : UserDto
      + OnChange : Action
      + SignIn(user)
      + SignOut()
    }
  }

  package "Shared View Models / UI Models" {
    class ChartBarVm {
      + Label : string
      + WaterHeight : int
      + GasHeight : int
      + WaterValueText : string
      + GasValueText : string
    }
  }
}

package "Application Contracts" {
  interface IIdentityAccessService {
    + RegisterAsync(command)
    + LoginAsync(command)
    + GetByIdAsync(id)
  }

  interface IDeviceManagementService {
    + RegisterAsync(command)
    + UpdateStatusAsync(command)
    + GetByOwnerAsync(ownerUserId)
  }

  interface IIncidentManagementService {
    + CreateAsync(command)
    + AssignAsync(command)
    + UpdateStatusAsync(command)
    + GetByDeviceAsync(deviceId)
  }

  interface IReportingService {
    + GenerateAsync(command)
    + GetByOwnerAsync(ownerUserId)
    + GetByOwnerAndPeriodAsync(ownerUserId, period)
  }

  class UserDto {
    + Id : Guid
    + Name : string
    + Email : string
    + Phone : string
    + Role : string
    + IsActive : bool
  }

  class DeviceDto {
    + Id : Guid
    + Name : string
    + Type : string
    + Status : string
    + Location : string
    + SensorsCount : int
    + ThresholdValue : decimal?
    + ThresholdUnit : string
  }

  class IncidentDto {
    + Id : Guid
    + DeviceId : Guid
    + ReportedByUserId : Guid
    + AssignedUserId : Guid?
    + Severity : string
    + Status : string
    + Description : string
    + CreatedAtUtc : DateTime
    + History : IReadOnlyCollection<string>
  }

  class ConsumptionReportDto {
    + Id : Guid
    + OwnerUserId : Guid
    + Period : string
    + TotalWaterConsumption : decimal
    + TotalWaterUnit : string
    + TotalGasConsumption : decimal
    + TotalGasUnit : string
    + GeneratedAtUtc : DateTime
  }
}

MainLayout ..> I18nService
MainLayout ..> UiSessionService

LoginPage ..> IIdentityAccessService
LoginPage ..> BrowserSessionService
LoginPage ..> UiSessionService
LoginPage ..> I18nService

RegisterPage ..> IIdentityAccessService
RegisterPage ..> BrowserSessionService
RegisterPage ..> UiSessionService
RegisterPage ..> I18nService

HomePage ..> IIdentityAccessService
HomePage ..> BrowserSessionService
HomePage ..> UiSessionService
HomePage ..> I18nService

DevicesPage ..> IIdentityAccessService
DevicesPage ..> IDeviceManagementService
DevicesPage ..> BrowserSessionService
DevicesPage ..> UiSessionService
DevicesPage ..> I18nService
DevicesPage ..> DeviceDto

ReportsPage ..> IIdentityAccessService
ReportsPage ..> IReportingService
ReportsPage ..> BrowserSessionService
ReportsPage ..> UiSessionService
ReportsPage ..> I18nService
ReportsPage ..> ConsumptionReportDto
ReportsPage ..> ChartBarVm

AlertsPage ..> IIdentityAccessService
AlertsPage ..> IIncidentManagementService
AlertsPage ..> IDeviceManagementService
AlertsPage ..> BrowserSessionService
AlertsPage ..> UiSessionService
AlertsPage ..> I18nService
AlertsPage ..> IncidentDto
AlertsPage ..> DeviceDto

ProfilePage ..> IIdentityAccessService
ProfilePage ..> BrowserSessionService
ProfilePage ..> UiSessionService
ProfilePage ..> I18nService
ProfilePage ..> UserDto

UiSessionService o-- UserDto
DevicesPage o-- DeviceDto
ReportsPage o-- ConsumptionReportDto
AlertsPage o-- IncidentDto
AlertsPage o-- DeviceDto

@enduml