@startuml
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam shadowing false

title LowCortisol - Diagrama de clases Backend

package "LowCortisol.Domain" {

    class Device {
        +Id : string
        +Name : string
        +Type : string
        +Icon : string
        +Signal : int
        +IsOnline : bool
    }

    class DeviceDetail {
        +Id : int
        +DeviceId : string
        +Location : string
        +Description : string
    }

    class SmartValve {
        +Id : int
        +Name : string
        +Zone : string
        +IsOpen : bool
        +Threshold : double
    }

    class Report {
        +Id : int
        +Title : string
        +WaterConsumption : double
        +GasConsumption : double
        +CreatedAt : DateTime
    }

    interface IDeviceRepository {
        +GetAll() : IEnumerable<Device>
        +GetById(id : string) : Device
        +Add(device : Device) : void
        +Update(device : Device) : void
        +Delete(id : string) : void
    }
}

package "LowCortisol.Application" {
    class DeviceService {
        +GetDevices() : IEnumerable<Device>
        +GetDeviceById(id : string) : Device
        +AddDevice(device : Device) : void
        +UpdateDevice(device : Device) : void
        +DeleteDevice(id : string) : void
    }
}

package "LowCortisol.Web.Auth" {
    class AppUser {
        +Id : int
        +Name : string
        +Email : string
        +Phone : string
        +PasswordHash : string
        +AccountType : string
    }

    class AppDbContext {
        +Users : DbSet<AppUser>
    }

    class AuthService {
        +RegisterAsync(name, email, phone, password, accountType)
        +LoginAsync(email, password)
        +LogoutAsync()
        +GetCurrentUserAsync() : AppUser
        +IsAuthenticatedAsync() : bool
    }
}

SmartValve --|> Device
Device "1" *-- "0..*" DeviceDetail
DeviceService ..> IDeviceRepository
DeviceService ..> Device
DeviceService ..> Report

AppDbContext "1" *-- "0..*" AppUser
AuthService ..> AppDbContext
AuthService ..> AppUser

@enduml