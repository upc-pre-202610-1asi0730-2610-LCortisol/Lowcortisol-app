@using Microsoft.JSInterop
@using System.Globalization
@using Microsoft.AspNetCore.Components
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject LowCortisol.Web.Services.I18nService I18n

<div class="ring-card">
    <div class="text-center text-sm tracking-widest font-semibold text-gray-500 mb-2">
        @Label
    </div>

    <div class="relative flex justify-center items-center">
        <div class="ring-soft-glow"></div>

        <svg @ref="_svgRef"
             width="170"
             height="170"
             viewBox="0 0 170 170"
             class="ring-svg">
            <circle cx="85"
                    cy="85"
                    r="58"
                    stroke="#edf2f7"
                    stroke-width="14"
                    fill="none" />

            <circle cx="85"
                    cy="85"
                    r="58"
                    stroke="@StrokeColor"
                    stroke-width="14"
                    fill="none"
                    stroke-linecap="round"
                    stroke-dasharray="@CircumferenceText"
                    stroke-dashoffset="@DashOffsetText"
                    transform="rotate(-90 85 85)"
                    class="ring-progress" />
        </svg>

        <div class="absolute text-center select-none pointer-events-none">
            <div class="text-[30px] leading-none font-black text-slate-900">
                @Value%
            </div>

            <div class="text-sm font-bold text-green-500 tracking-wider mt-2">
                @(Value > 0 ? I18n["home.open"] : I18n["home.closed"])
            </div>
        </div>
    </div>

    <p class="text-center text-sm text-gray-500 mt-3">
        @I18n["home.dragHint"]
    </p>
</div>

@code {
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public int Value { get; set; }
    [Parameter] public EventCallback<int> ValueChanged { get; set; }
    [Parameter] public string StrokeColor { get; set; } = "#1b84f4";

    private ElementReference _svgRef;
    private DotNetObjectReference<CircularRing>? _dotNetRef;
    private IJSObjectReference? _module;
    private IJSObjectReference? _instance;

    private const double Radius = 58;
    private double Circumference => 2 * Math.PI * Radius;
    private double DashOffset => Circumference * (1 - (Math.Clamp(Value, 0, 100) / 100.0));

    private string CircumferenceText => Circumference.ToString(CultureInfo.InvariantCulture);
    private string DashOffsetText => DashOffset.ToString(CultureInfo.InvariantCulture);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _module = await JS.InvokeAsync<IJSObjectReference>("import", "/js/circularRing.js");
        _dotNetRef = DotNetObjectReference.Create(this);
        _instance = await _module.InvokeAsync<IJSObjectReference>("attachCircularRing", _svgRef, _dotNetRef);
    }

    [JSInvokable]
    public async Task UpdateFromJs(int newValue)
    {
        newValue = Math.Clamp(newValue, 0, 100);

        if (newValue != Value)
            await ValueChanged.InvokeAsync(newValue);
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_instance is not null)
            {
                await _instance.InvokeVoidAsync("dispose");
                await _instance.DisposeAsync();
            }

            if (_module is not null)
                await _module.DisposeAsync();
        }
        catch
        {
        }

        _dotNetRef?.Dispose();
    }
}