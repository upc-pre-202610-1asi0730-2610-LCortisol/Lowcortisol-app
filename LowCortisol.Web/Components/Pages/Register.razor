@page "/register"
@rendermode InteractiveServer

@inject LowCortisol.Web.Auth.AuthService Auth
@inject NavigationManager Nav
@inject LowCortisol.Web.Services.I18nService I18n

<div class="auth-page">
    <div class="auth-card">
        <h1 class="auth-title">@I18n["auth.registerTitle"]</h1>
        <p class="auth-subtitle">@I18n["auth.registerSubtitle"]</p>

        @if (!string.IsNullOrWhiteSpace(error))
        {
            <div class="auth-error">@error</div>
        }

        <div class="auth-field">
            <label>@I18n["auth.name"]</label>
            <input class="auth-input"
                   @bind="name"
                   placeholder="@I18n["auth.namePlaceholder"]" />
        </div>

        <div class="auth-field">
            <label>@I18n["auth.email"]</label>
            <input class="auth-input"
                   @bind="email"
                   placeholder="@I18n["auth.emailPlaceholder"]" />
        </div>

        <div class="auth-field">
            <label>@I18n["auth.phone"]</label>
            <input class="auth-input"
                   @bind="phone"
                   placeholder="@I18n["auth.phonePlaceholder"]" />
        </div>

        <div class="auth-field">
            <label>@I18n["auth.password"]</label>
            <input class="auth-input"
                   type="password"
                   @bind="password"
                   placeholder="@I18n["auth.createPasswordPlaceholder"]" />
        </div>

        <div class="auth-field">
            <label>@I18n["auth.accountType"]</label>
            <select class="auth-input" @bind="accountType">
                <option value="Homeowner">@I18n["auth.accountType.homeowner"]</option>
                <option value="Admin">@I18n["auth.accountType.admin"]</option>
                <option value="Technician">@I18n["auth.accountType.technician"]</option>
            </select>
        </div>

        <button class="auth-primary-btn" @onclick="RegisterUser">
            @I18n["auth.createAccount"]
        </button>

        <a class="auth-link" href="/">@I18n["auth.backToLogin"]</a>
    </div>
</div>

@code {
    private string name = "";
    private string email = "";
    private string phone = "";
    private string password = "";
    private string accountType = "Homeowner";
    private string error = "";
    private bool _checkedAuth = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _checkedAuth)
            return;

        _checkedAuth = true;

        var isAuthenticated = await Auth.IsAuthenticatedAsync();
        if (isAuthenticated)
        {
            Nav.NavigateTo("/", forceLoad: true);
            return;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task RegisterUser()
    {
        error = "";

        var result = await Auth.RegisterAsync(name, email, phone, password, accountType);

        if (!result.Ok)
        {
            error = result.Error;
            return;
        }

        Nav.NavigateTo("/home");
    }
}