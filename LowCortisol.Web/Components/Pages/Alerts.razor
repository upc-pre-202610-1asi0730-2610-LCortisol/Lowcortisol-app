@page "/alerts"
@rendermode InteractiveServer
@implements IDisposable
@inject LowCortisol.Web.Services.I18nService I18n

<div class="space-y-5">
    <h1 class="page-title">@I18n["alerts.title"]</h1>
    <div class="section-divider"></div>

    @foreach (var item in alerts)
    {
        <div class="soft-card p-4 flex items-center justify-between gap-4 fade-up">
            <div class="flex items-center gap-4">
                <div class="icon-chip @item.IconClass text-xl">@item.Icon</div>
                <div>
                    <div class="text-xl font-semibold">@item.Title</div>
                    <div class="text-base text-gray-500">@item.Description</div>
                </div>
            </div>
            <div class="text-xs tracking-widest text-gray-500 whitespace-nowrap">@item.When</div>
        </div>
    }
</div>

@code {
    private List<AlertItem> alerts = new();

    protected override void OnInitialized()
    {
        I18n.OnChange += RefreshAlerts;
        RefreshAlerts();
    }

    private void RefreshAlerts()
    {
        alerts = new()
        {
            new("💧", "bg-chip-red", I18n["alerts.waterLeakTitle"], I18n["alerts.waterLeakDesc"], I18n["alerts.twoMinAgo"]),
            new("🔥", "bg-chip-orange", I18n["alerts.gasLowTitle"], I18n["alerts.gasLowDesc"], I18n["alerts.oneHourAgo"]),
            new("🔋", "bg-chip-orange", I18n["alerts.batteryLowTitle"], I18n["alerts.batteryLowDesc"], I18n["alerts.threeHoursAgo"]),
            new("〰", "bg-chip-blue", I18n["alerts.flowTitle"], I18n["alerts.flowDesc"], I18n["alerts.yesterday"]),
            new("◉", "bg-chip-blue", I18n["alerts.reconnectedTitle"], I18n["alerts.reconnectedDesc"], I18n["alerts.yesterday"]),
            new("⚠", "bg-chip-blue", I18n["alerts.checkTitle"], I18n["alerts.checkDesc"], I18n["alerts.twoDaysAgo"])
        };

        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        I18n.OnChange -= RefreshAlerts;
    }

    public record AlertItem(string Icon, string IconClass, string Title, string Description, string When);
}