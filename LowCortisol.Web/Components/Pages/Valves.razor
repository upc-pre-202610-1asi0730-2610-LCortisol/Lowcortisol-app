@page "/valves"
@rendermode InteractiveServer
@implements IDisposable
@using System.Globalization
@inject LowCortisol.Web.Services.AppStateService AppState
@inject LowCortisol.Web.Services.I18nService I18n

<div class="space-y-5">
    <h1 class="page-title">@I18n["valves.title"]</h1>
    <div class="section-divider"></div>

    <div class="soft-card-sm p-1 flex">
        <button class="flex-1 rounded-2xl py-4 font-bold transition @(tab == "AUTO" ? "bg-white shadow text-black" : "text-gray-500")"
                @onclick="SetAuto">
            @I18n["valves.auto"]
        </button>

        <button class="flex-1 rounded-2xl py-4 font-bold transition @(tab == "MANUAL" ? "bg-white shadow text-black" : "text-gray-500")"
                @onclick="SetManual">
            @I18n["valves.manual"]
        </button>
    </div>

    @foreach (var valve in AppState.Valves)
    {
        <div class="soft-card p-5 space-y-4 fade-up @(valve.IsOn ? "" : "opacity-60")">
            <div class="flex justify-between items-start">
                <div>
                    <div class="text-2xl font-semibold">@ValveName(valve.Id)</div>
                    <div class="text-base text-gray-500">@ValveLocation(valve.Id)</div>
                </div>

                <button @onclick="() => ToggleValve(valve.Id)" class="bg-transparent border-0 p-0">
                    <div class="switch-wrap @(valve.IsOn ? "on" : "off")">
                        <div class="switch-thumb"></div>
                    </div>
                </button>
            </div>

            <div class="flex justify-between items-center">
                <div class="text-sm tracking-widest text-gray-500 font-semibold">
                    @I18n["valves.threshold"]
                </div>

                <div class="text-2xl font-semibold">
                    @FormatThreshold(valve)
                </div>
            </div>

            <input type="range"
                   min="@valve.Min.ToString(CultureInfo.InvariantCulture)"
                   max="@valve.Max.ToString(CultureInfo.InvariantCulture)"
                   step="@valve.Step.ToString(CultureInfo.InvariantCulture)"
                   value="@valve.Threshold.ToString(CultureInfo.InvariantCulture)"
                   disabled="@(!valve.IsOn)"
                   class="range-slider @(valve.IsOn ? "" : "range-slider-off")"
                   style="@GetSliderStyle(valve)"
                   @oninput="(e) => UpdateThreshold(valve.Id, e.Value?.ToString())" />
        </div>
    }
</div>

@code {
    private string tab = "AUTO";

    protected override void OnInitialized()
    {
        AppState.OnChange += Refresh;
        I18n.OnChange += Refresh;
    }

    private void SetAuto() => tab = "AUTO";
    private void SetManual() => tab = "MANUAL";

    private void ToggleValve(string id)
    {
        AppState.ToggleValve(id);
    }

    private void UpdateThreshold(string id, string? rawValue)
    {
        if (double.TryParse(rawValue, NumberStyles.Any, CultureInfo.InvariantCulture, out var value))
        {
            AppState.UpdateValveThreshold(id, value);
        }
        else if (double.TryParse(rawValue, out value))
        {
            AppState.UpdateValveThreshold(id, value);
        }
    }

    private string FormatThreshold(LowCortisol.Web.Services.ValveState valve)
    {
        if (valve.Unit == "bar")
            return $"{valve.Threshold.ToString("0.0", new CultureInfo("es-ES"))} {valve.Unit}";

        return $"{Math.Round(valve.Threshold):0} {valve.Unit}";
    }

    private string GetSliderStyle(LowCortisol.Web.Services.ValveState valve)
    {
        var range = valve.Max - valve.Min;
        if (range <= 0) return "";

        var percent = ((valve.Threshold - valve.Min) / range) * 100.0;
        percent = Math.Clamp(percent, 0, 100);

        var fillColor = valve.IsOn ? "#1677ff" : "#bfdbfe";
        var emptyColor = "#e9edf2";

        var percentText = percent.ToString("0.##", CultureInfo.InvariantCulture);

        return $"background: linear-gradient(to right, {fillColor} 0%, {fillColor} {percentText}%, {emptyColor} {percentText}%, {emptyColor} 100%);";
    }

    private string ValveName(string id) => id switch
    {
        "water-main" => I18n["valves.mainWater"],
        "kitchen-line" => I18n["valves.kitchenLine"],
        "gas-main" => I18n["valves.gasMain"],
        "garden-valve" => I18n["valves.gardenValve"],
        _ => id
    };

    private string ValveLocation(string id) => id switch
    {
        "water-main" => I18n["valves.basement"],
        "kitchen-line" => I18n["valves.groundFloor"],
        "gas-main" => I18n["valves.utilityRoom"],
        "garden-valve" => I18n["valves.outdoor"],
        _ => ""
    };

    private void Refresh() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        AppState.OnChange -= Refresh;
        I18n.OnChange -= Refresh;
    }
}