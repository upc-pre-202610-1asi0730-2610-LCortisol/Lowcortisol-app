@page "/"
@rendermode InteractiveServer

@inject LowCortisol.Web.Auth.AuthService Auth
@inject NavigationManager Nav

<div class="soft-card p-8 text-center text-gray-500">
    Loading...
</div>

@code {
    private bool _checked;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _checked)
            return;

        _checked = true;

        var isAuthenticated = await Auth.IsAuthenticatedAsync();

        if (isAuthenticated)
            Nav.NavigateTo("/home", forceLoad: true);
        else
            Nav.NavigateTo("/login", forceLoad: true);

        await InvokeAsync(StateHasChanged);
    }
}