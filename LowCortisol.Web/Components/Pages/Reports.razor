@page "/reports"
@rendermode InteractiveServer
@implements IDisposable
@using LowCortisol.Application.Services
@using LowCortisol.Domain.Entities
@inject DeviceService DeviceService
@inject LowCortisol.Web.Services.I18nService I18n

<div class="space-y-5">
    <div class="flex items-center gap-4">
        <a href="/profile" class="top-back">‹</a>
        <h1 class="page-title">@I18n["reports.title"]</h1>
    </div>

    <div class="section-divider"></div>

    @if (report is null)
    {
        <div class="soft-card p-8 text-center text-gray-500">
            Loading report...
        </div>
    }
    else
    {
        <div class="grid grid-cols-2 gap-3">
            <div class="rounded-[22px] p-5 text-white shadow-lg bg-gradient-to-r from-sky-500 to-blue-500">
                <div class="text-sm font-bold tracking-widest opacity-90">@I18n["reports.water"]</div>
                <div class="text-5xl font-black mt-2">@report.WaterConsumption.ToString("F0") L</div>
            </div>

            <div class="rounded-[22px] p-5 text-white shadow-lg bg-gradient-to-r from-orange-500 to-orange-600">
                <div class="text-sm font-bold tracking-widest opacity-90">@I18n["reports.gas"]</div>
                <div class="text-5xl font-black mt-2">@report.GasConsumption.ToString("F0") m³</div>
            </div>
        </div>

        <div class="soft-card p-5">
            <div class="flex items-center justify-between mb-6">
                <h2 class="text-xl font-bold">@I18n["reports.consumption"]</h2>

                <div class="bg-gray-100 rounded-full p-1 flex">
                    @foreach (var p in new[] { "7D", "30D", "90D" })
                    {
                        <button type="button"
                                class="px-4 py-2 text-sm font-bold rounded-full transition @(selectedPeriod == p ? "bg-white shadow text-black" : "text-gray-500")"
                                @onclick="() => LoadData(p)">
                            @p
                        </button>
                    }
                </div>
            </div>

            <svg viewBox="0 0 360 170" class="w-full h-56 overflow-visible">
                @for (int i = 0; i < chartData.Count; i++)
                {
                    var item = chartData[i];
                    var x = i * (360.0 / chartData.Count) + 4;
                    var barWidth = (360.0 / chartData.Count) - 6;
                    var waterHeight = item.Water;
                    var gasHeight = item.Gas;

                    <rect class="chart-bar"
                          x="@x"
                          y="@(145 - waterHeight)"
                          width="@barWidth"
                          height="@waterHeight"
                          rx="4"
                          fill="#1b84f4" />

                    <rect class="chart-bar"
                          x="@x"
                          y="@(145 - waterHeight - gasHeight)"
                          width="@barWidth"
                          height="@gasHeight"
                          rx="4"
                          fill="#ff6a13" />
                }
            </svg>
        </div>

        <button class="secondary-btn">
            🗓 @I18n["reports.filter"]
        </button>

        <button class="primary-btn">
            ⬇ @I18n["reports.export"]
        </button>
    }
</div>

@code {
    private Report? report;
    private string selectedPeriod = "30D";
    private List<ChartBarVm> chartData = new();

    protected override async Task OnInitializedAsync()
    {
        I18n.OnChange += Refresh;
        await LoadData("30D");
    }

    private async Task LoadData(string period)
    {
        selectedPeriod = period;
        report = await DeviceService.GetReportsAsync(period);

        chartData = period switch
        {
            "7D" => new()
            {
                new(48, 14), new(60, 12), new(42, 10), new(74, 16), new(68, 13), new(57, 15), new(65, 12)
            },
            "90D" => GenerateBars(20, 38, 78, 8, 20),
            _ => GenerateBars(15, 42, 82, 10, 22)
        };
    }

    private List<ChartBarVm> GenerateBars(int count, int minWater, int maxWater, int minGas, int maxGas)
    {
        var rng = new Random(42 + count);
        var list = new List<ChartBarVm>();

        for (int i = 0; i < count; i++)
        {
            list.Add(new ChartBarVm(
                rng.Next(minWater, maxWater),
                rng.Next(minGas, maxGas)
            ));
        }

        return list;
    }

    private void Refresh() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        I18n.OnChange -= Refresh;
    }

    public record ChartBarVm(int Water, int Gas);
}