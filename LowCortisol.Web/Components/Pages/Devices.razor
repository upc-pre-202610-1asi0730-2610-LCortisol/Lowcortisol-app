@page "/devices"
@rendermode InteractiveServer
@implements IDisposable

@inject LowCortisol.Web.Services.AppStateService AppState
@inject LowCortisol.Web.Services.I18nService I18n

<div class="space-y-5">
    <div class="flex items-center gap-3">
        <a href="/profile" class="top-back">‹</a>
        <h1 class="page-title">@I18n["devices.title"]</h1>
    </div>

    <div class="section-divider"></div>

    <div class="grid grid-cols-2 gap-3">
        @foreach (var item in AppState.Devices)
        {
            <div class="soft-card p-[18px] device-card fade-up @(item.IsOnline ? "" : "device-card-offline")">
                <div class="flex items-start justify-between gap-2">
                    <div class="flex items-center gap-2">
                        <div class="icon-chip @(item.IsOnline ? "bg-chip-blue" : "bg-chip-gray") text-2xl">
                            @item.Icon
                        </div>

                        <div class="signal-bars @(item.IsOnline ? "" : "offline")">
                            <span class="bar @(item.Signal >= 1 ? "active" : "")"></span>
                            <span class="bar @(item.Signal >= 2 ? "active" : "")"></span>
                            <span class="bar @(item.Signal >= 3 ? "active" : "")"></span>
                            <span class="bar @(item.Signal >= 4 ? "active" : "")"></span>
                        </div>
                    </div>

                    <button type="button"
                            class="device-toggle @(item.IsOnline ? "on" : "off")"
                            @onclick="() => ToggleDevice(item.Id)">
                        @(item.IsOnline ? "ON" : "OFF")
                    </button>
                </div>

                <div class="mt-5">
                    <div class="text-[16px] leading-[1.15] font-bold text-slate-900">
                        @item.Name
                    </div>

                    <div class="text-sm text-gray-500 mt-1">
                        @DeviceTypeLabel(item.Type)
                    </div>
                </div>

                <div class="mt-4 text-sm font-bold @(item.IsOnline ? "device-online" : "device-offline")">
                    <span class="mr-1">•</span>
                    @(item.IsOnline ? I18n["devices.online"] : I18n["devices.offline"])
                </div>
            </div>
        }
    </div>

    <button type="button" class="add-device-btn" @onclick="OpenAddDeviceModal">
        + @I18n["devices.add"]
    </button>
</div>

@code {
    protected override void OnInitialized()
    {
        AppState.OnChange += Refresh;
        I18n.OnChange += Refresh;
    }

    private void ToggleDevice(string id)
    {
        AppState.ToggleDevice(id);
    }

    private void OpenAddDeviceModal()
    {
        // Si ya tienes modal, aquí llamas a tu lógica.
        // Ejemplo:
        // showAddModal = true;
    }

    private string DeviceTypeLabel(string? type)
    {
        return type?.ToLowerInvariant() switch
        {
            "smart valve" => I18n["devices.smartValve"],
            "leak sensor" => I18n["devices.leakSensor"],
            "sensor" => I18n["devices.sensor"],
            "hub" => I18n["devices.hub"],
            _ => type ?? ""
        };
    }

    private void Refresh()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        AppState.OnChange -= Refresh;
        I18n.OnChange -= Refresh;
    }
}